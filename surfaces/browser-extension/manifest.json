{
  "manifest_version": 3,
  "name": "waterusedbyourAi",
  "version": "0.1.0",
  "description": "See the water, energy & CO2 behind your AI chats. Honest per-prompt estimates, computed 100% in your browser.",
  "content_scripts": [
    {
      "matches": [
        "https://*.claude.ai/*",
        "https://*.chatgpt.com/*",
        "https://*.openai.com/*",
        "https://*.perplexity.ai/*",
        "https://*.perploxity.ai/*",
        "https://*.perplexity.zi/*",
        "https://*.perploxity.zi/*",
        "https://*.gemini.google.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Thirsty — AI Water Meter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "minimum_chrome_version": "110"
}
