{
  "name": "@waterusedbyourai/browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "MV3 extension that shows a live water/energy/CO2 meter on AI chats.",
  "type": "module",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "icons": "node icons/generate-icons.mjs",
    "package": "npm run build && node scripts/package.cjs",
    "verify:live": "node scripts/verify-live.mjs"
  },
  "dependencies": {
    "@waterusedbyourai/core": "*"
  }
}
