{
  "name": "waterusedbyourai",
  "version": "0.1.0",
  "private": true,
  "description": "A prompt-footprint meter for AI chats — estimate the water, energy, and CO2 behind every prompt. Plug-in platform: one core engine, many surfaces.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "surfaces/*",
    "plugins/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty",
    "build:ext": "npm run build --workspace @waterusedbyourai/browser-extension"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
